# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/


# Added by cargo

/target

# Ignore the generated data directory, which contains the output of the build script
/data

# Ignore the generated .env file, which may contain sensitive information
.env

# Ignore local Commander memory and runtime state
/.commander/

/tmp
/.cache/

# Ignore the outputs directory, which may contain generated files or logs
/outputs/

# Confidential document files
# Microsoft Office
**/*.xlsx
**/*.xlsm
**/*.xlsb
**/*.xls
**/*.docx
**/*.docm
**/*.doc
**/*.pptx
**/*.pptm
**/*.ppt
# PDF
**/*.pdf
# Apple iWork
**/*.pages
**/*.numbers
**/*.key
# OpenDocument
**/*.ods
**/*.odt
**/*.odp
# CSV / TSV (may contain personal or business data)
**/*.csv
**/*.tsv
